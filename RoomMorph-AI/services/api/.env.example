APP_ENV=development
PUBLIC_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
STORAGE_ROOT=storage

# Real room redesign image generation.
IMAGE_GENERATION_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=auto
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_INPUT_FIDELITY=high
OPENAI_IMAGE_OUTPUT_FORMAT=jpeg
OPENAI_IMAGE_TIMEOUT_SECONDS=180

# Set IMAGE_GENERATION_PROVIDER=local to use the deterministic development fallback.
