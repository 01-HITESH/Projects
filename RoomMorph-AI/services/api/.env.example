APP_ENV=development
PUBLIC_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
STORAGE_ROOT=storage

# Real room redesign image generation.
# automatic1111 = local Stable Diffusion WebUI at SD_WEBUI_URL.
# openai = OpenAI Image API.
# local = deterministic development fallback with no AI.
IMAGE_GENERATION_PROVIDER=automatic1111
SD_WEBUI_URL=http://127.0.0.1:7860
SD_WEBUI_STEPS=30
SD_WEBUI_CFG_SCALE=7.0
SD_WEBUI_DENOISING_STRENGTH=0.62
SD_WEBUI_SAMPLER_NAME=DPM++ 2M Karras
SD_WEBUI_MAX_SIZE=1024
SD_WEBUI_STATUS_TIMEOUT_SECONDS=5
SD_WEBUI_TIMEOUT_SECONDS=240

OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=auto
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_INPUT_FIDELITY=high
OPENAI_IMAGE_OUTPUT_FORMAT=jpeg
OPENAI_IMAGE_TIMEOUT_SECONDS=180

# Set IMAGE_GENERATION_PROVIDER=local to use the deterministic development fallback.
